@page "/generate"
@using MoodBoardGenerator.Shared.Models
@using Microsoft.AspNetCore.Components.Forms
@using MoodBoardGenerator.Client.Services

@inject IMoodBoardApiService ApiService
@inject IMoodBoardStateService StateService
@inject NavigationManager Navigation

<PageTitle>Создать мудборд</PageTitle>

<div class="generate-container">
    <div class="generate-form">
        <h2 class="mb-3">Создать новый мудборд</h2>
        <p class="text-muted">Введите тему и описание, а мы сгенерируем уникальный мудборд</p>

        @if (isGenerating)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
                <p class="mt-3 text-muted">Генерация вашего мудборда...</p>
            </div>
        }
        else
        {
            <EditForm Model="@request" OnValidSubmit="@HandleGenerate">
                <div class="mb-3">
                    <label for="theme" class="form-label">Тема *</label>
                    <InputText id="theme" class="form-control" @bind-Value="request.Theme" 
                               placeholder="Например: Осеннее настроение, Минимализм, Космическая тема" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Описание</label>
                    <InputTextArea id="description" class="form-control" @bind-Value="request.Description" 
                                   rows="3" placeholder="Опишите, что вы хотите видеть на мудборде..." />
                </div>

                <div class="mb-4">
                    <label for="style" class="form-label">Стиль</label>
                    <InputSelect id="style" class="form-select" @bind-Value="request.Style">
                        @foreach (MoodStyle style in Enum.GetValues(typeof(MoodStyle)))
                        {
                            <option value="@style">@style</option>
                        }
                    </InputSelect>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isGenerating">
                    @(isGenerating ? "Генерация..." : "Генерировать")
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    private GenerateRequest request = new();
    private bool isGenerating = false;

    private async Task HandleGenerate()
    {
        isGenerating = true;
        try
        {
            var board = await ApiService.GenerateMoodBoardAsync(
                request.Theme,
                request.Description ?? string.Empty,
                request.Style
            );
            
            StateService.CurrentBoard = board;
            Navigation.NavigateTo($"/board/{board.Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating mood board: {ex.Message}");
        }
        finally
        {
            isGenerating = false;
        }
    }

    private class GenerateRequest
    {
        public string Theme { get; set; } = string.Empty;
        public string? Description { get; set; }
        public MoodStyle Style { get; set; } = MoodStyle.Minimalist;
    }
}

<style>
    .generate-container {
        display: flex;
        justify-content: center;
        padding: 2rem 0;
    }
    .generate-form {
        max-width: 600px;
        width: 100%;
        background: white;
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }
    .generate-form h2 {
        color: #1a1a2e;
        font-weight: 600;
    }
    .form-label {
        font-weight: 500;
        color: #1a1a2e;
    }
    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        padding: 0.6rem 1rem;
    }
    .form-control:focus, .form-select:focus {
        border-color: #1a1a2e;
        box-shadow: 0 0 0 0.2rem rgba(26,26,46,0.1);
    }
    .btn-primary {
        background: #1a1a2e;
        border-color: #1a1a2e;
        padding: 0.75rem;
        font-weight: 500;
        border-radius: 8px;
    }
    .btn-primary:hover {
        background: #16213e;
        border-color: #16213e;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(26,26,46,0.3);
    }
    .btn-primary:disabled {
        background: #6c757d;
        border-color: #6c757d;
    }
</style>