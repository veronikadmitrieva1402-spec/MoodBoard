@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    html, body {
        height: 100%;
        width: 100%;
        overflow-x: hidden;
        background: url('https://img.freepik.com/free-vector/ornamental-vintage-wallpaper_23-2148663182.jpg?semt=ais_hybrid&w=740&q=80') no-repeat center center fixed;
        background-size: cover;
    }
    
    .page {
        display: flex;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.1);
    }
    
    .sidebar {
        width: 250px;
        min-width: 250px;
        background: rgba(26, 26, 46, 0.9);
        backdrop-filter: blur(10px);
        color: white;
        padding: 1rem;
        height: 100vh;
        overflow-y: auto;
        flex-shrink: 0;
        border-right: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
        min-width: 0;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(5px);
    }
    
    .top-row {
        display: flex;
        justify-content: flex-end;
        padding: 0.75rem 1.5rem;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(5px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        flex-shrink: 0;
    }
    
    .top-row a {
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
    }
    .top-row a:hover {
        color: white;
    }
    
    .content {
        flex: 1;
        padding: 1.5rem;
        overflow-y: auto;
        overflow-x: hidden;
        width: 100%;
        max-width: 100%;
    }
    
    .content .hero-section,
    .content .feature-card,
    .content .generate-form,
    .content .edit-form,
    .content .board-header,
    .content .board-item,
    .content .board-card,
    .content .empty-state {
        background: rgba(255, 255, 255, 0.9) !important;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .content .board-header {
        background: rgba(255, 255, 255, 0.95) !important;
    }
    
</style>